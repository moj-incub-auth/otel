{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Search API Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=\"milvus\", job=\"moj-search-api-metrics\"}[5m])) by (method, status)",
          "legendFormat": "{{ method }} {{ status }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      }
    },
    {
      "title": "Search API Latency P95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{namespace=\"milvus\", job=\"moj-search-api-metrics\"}[5m])) by (le))",
          "legendFormat": "P95"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      }
    },
    {
      "title": "Search API Error Rate",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=\"milvus\", job=\"moj-search-api-metrics\", status=~\"5..\"}[5m])) / sum(rate(http_requests_total{namespace=\"milvus\", job=\"moj-search-api-metrics\"}[5m]))",
          "legendFormat": "Error Rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Milvus Query Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(milvus_query_duration_seconds_bucket{namespace=\"milvus\"}[5m])) by (le))",
          "legendFormat": "P95 Milvus Query"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["search", "moj", "milvus"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "MOJ Search API",
  "uid": "moj-search-dashboard"
}
